    let currentQ = 0;
    let score = 0;

    function loadQuestion() {
        const qEl = document.getElementById('question');
        const optEl = document.getElementById('options');
        if(currentQ < questions.length) {
            qEl.innerText = (currentQ + 1) + ". " + questions[currentQ].q;
            optEl.innerHTML = "";
            questions[currentQ].a.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(index);
                optEl.appendChild(btn);
            });
        } else {
            document.getElementById('quiz-container').style.display = 'none';
            document.getElementById('score-board').style.display = 'block';
            document.getElementById('score-board').innerText = `আপনার স্কোর: ${score} / ${questions.length}`;
        }
    }

    function checkAnswer(index) {
        if(index === questions[currentQ].correct) score++;
        currentQ++;
        loadQuestion();
    }

    loadQuestion();
